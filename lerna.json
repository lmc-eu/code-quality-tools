{
  "packages": ["packages/*"],
  "version": "independent",
  "npmClient": "yarn",
  "command": {
    "version": {
      "allowBranch": ["release"],
      "conventionalCommits": true,
      "changelogPreset": "./changelog-preset.config.cjs",
      "createRelease": "github",
      "push": false,
      "ignoreChanges": ["test/**", "yarn.lock"]
    },
    "publish": {
      "message": "chore(release): publish"
    }
  }
}
